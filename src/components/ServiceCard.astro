---
import type { Service } from "../types";

interface Props {
  service: Service;
  isPrivate?: boolean;
}

const { service, isPrivate = false } = Astro.props;

const statusColor = {
  online: { dot: "bg-emerald-500", text: "text-emerald-500" },
  limited: { dot: "bg-amber-500", text: "text-amber-500" },
  offline: { dot: "bg-red-500", text: "text-red-500" },
}[service.status];
---

<a
  class:list={[
    "group glass-card p-6 rounded-xl border border-outline-variant/15 hover:bg-surface-bright transition-all duration-300 flex flex-col justify-between",
    service.span,
  ]}
  href={service.url}
  target="_blank"
  rel="noopener noreferrer"
>
  <div>
    <div class="flex justify-between items-start mb-6">
      <div class="p-3 bg-secondary-container rounded-md">
        <span class="material-symbols-outlined text-primary">{service.icon}</span>
      </div>
      <div class="flex items-center gap-2">
        <span class:list={["w-1.5 h-1.5 rounded-full", statusColor.dot]}></span>
        <span class:list={["font-label text-[0.6rem] uppercase", statusColor.text]}>
          {service.status}
        </span>
      </div>
    </div>
    <h3 class="font-headline text-xl font-bold mb-2 group-hover:text-primary transition-colors flex items-center gap-2">
      {isPrivate && <span class="material-symbols-outlined text-base text-on-surface-variant/50">lock</span>}
      {service.name}
    </h3>
    <p class="text-on-surface-variant text-sm leading-relaxed">{service.description}</p>
  </div>
</a>
