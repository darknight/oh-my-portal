---
import ServiceCard from "./ServiceCard.astro";
import { publicServices, privateServices } from "../data/services";
---

<section id="services" class="mb-14">
  <div class="flex items-center justify-between mb-10">
    <h2 class="font-headline text-2xl font-bold tracking-tight">Public Services</h2>
    <div class="h-[1px] flex-grow mx-8 bg-surface-variant/40"></div>
    <span class="font-label text-[0.6875rem] uppercase tracking-widest text-on-surface-variant">
      Open_Access
    </span>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {publicServices.map((service) => <ServiceCard service={service} />)}
  </div>
</section>

<section id="private-services" class="mb-14">
  <div class="flex items-center justify-between mb-10">
    <h2 class="font-headline text-2xl font-bold tracking-tight">Private Services</h2>
    <div class="h-[1px] flex-grow mx-8 bg-surface-variant/40"></div>
    <span class="font-label text-[0.6875rem] uppercase tracking-widest text-on-surface-variant">
      Auth_Required
    </span>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {privateServices.map((service) => <ServiceCard service={service} isPrivate />)}
  </div>
</section>
