---
const year = new Date().getFullYear();

const footerLinks = [
  { label: "GitHub", href: "https://github.com/darknight" },
];
---

<footer class="bg-surface py-12 border-t border-outline-variant/15">
  <div class="max-w-screen-2xl mx-auto px-10 flex flex-col md:flex-row justify-between items-center w-full gap-8">
    <div class="order-2 md:order-1">
      <p class="font-body text-[0.75rem] text-on-surface-variant/40 uppercase tracking-widest">
        &copy; {year} ILLUMINATING.ME
      </p>
    </div>
    <div class="flex items-center space-x-8 order-1 md:order-2">
      {footerLinks.map((link) => (
        <a
          class="text-on-surface-variant/40 font-label text-[0.6875rem] uppercase hover:text-primary underline decoration-2 underline-offset-4 transition-all"
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
