<section class="mb-24 mt-8 flex flex-col md:flex-row justify-between items-end gap-12">
  <div class="max-w-3xl">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      <span class="font-label text-[0.6875rem] uppercase tracking-widest text-primary">
        System Status: Optimal
      </span>
    </div>
    <h1 class="font-headline text-5xl md:text-[5.5rem] leading-[0.95] font-bold tracking-tighter mb-8 text-on-surface">
      ILLUMINATING<span class="text-primary">.</span>ME
    </h1>
    <p class="text-xl md:text-2xl text-on-surface-variant max-w-xl font-light leading-relaxed">
      Building small tools with AI to solve everyday problems. Learning by shipping.
    </p>
    <div class="mt-10 flex items-center gap-6">
      <a
        href="#services"
        class="bg-primary text-on-primary px-8 py-3 rounded-md font-label text-xs uppercase tracking-widest font-bold hover:brightness-110 transition-all active:scale-95"
      >
        Explore Services
      </a>
      <div class="h-[1px] w-20 bg-outline-variant opacity-30"></div>
    </div>
  </div>
  <div class="hidden lg:block">
    <div class="glass-card p-6 rounded-xl border border-outline-variant/15 ambient-glow">
      <div class="font-label text-[0.6875rem] uppercase tracking-widest text-on-surface-variant mb-4">
        Core_Metrics
      </div>
      <div class="space-y-4">
        <div class="flex justify-between items-center gap-12">
          <span class="text-xs text-on-surface-variant/70">Services</span>
          <span class="font-label text-primary">5 Active</span>
        </div>
        <div class="flex justify-between items-center gap-12">
          <span class="text-xs text-on-surface-variant/70">Platform</span>
          <span class="font-label text-primary">Cloudflare</span>
        </div>
      </div>
    </div>
  </div>
</section>
